{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Severity Entry",
  "description": "Corporate-language translators for outages, degradation notices, and carefully managed understatement.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "category",
    "title",
    "summary",
    "tags",
    "tone",
    "version",
    "created_at",
    "updated_at",
    "phrase",
    "translation",
    "escalation_level",
    "blast_radius",
    "recommended_message"
  ],
  "properties": {
    "id": {
      "type": "string",
      "description": "Stable slug for the entry."
    },
    "category": {
      "type": "string",
      "description": "Category slug used in API paths."
    },
    "title": {
      "type": "string",
      "description": "Display title."
    },
    "summary": {
      "type": "string",
      "description": "Short, high-signal description."
    },
    "tags": {
      "type": "array",
      "description": "Searchable tags for browsing and filtering.",
      "items": {
        "type": "string"
      },
      "minItems": 1
    },
    "tone": {
      "type": "string",
      "description": "Primary writing mode."
    },
    "version": {
      "type": "string",
      "description": "Content object schema version."
    },
    "created_at": {
      "type": "string",
      "description": "Initial publication date in ISO local date form."
    },
    "updated_at": {
      "type": "string",
      "description": "Most recent update date in ISO local date form."
    },
    "phrase": {
      "type": "string",
      "description": "Original corporate or incident phrase."
    },
    "translation": {
      "type": "string",
      "description": "What it means in plain language."
    },
    "escalation_level": {
      "type": "string",
      "description": "Implied urgency level.",
      "enum": [
        "low",
        "medium",
        "high",
        "critical"
      ]
    },
    "blast_radius": {
      "type": "string",
      "description": "How wide the problem feels from the outside."
    },
    "recommended_message": {
      "type": "string",
      "description": "Clearer sentence to use instead."
    }
  }
}
