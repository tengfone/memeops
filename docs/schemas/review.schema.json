{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Review Entry",
  "description": "Pull request and design review lines where the visible comment and the actual concern are politely decoupled.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "category",
    "title",
    "summary",
    "tags",
    "tone",
    "version",
    "created_at",
    "updated_at",
    "feedback",
    "subtext",
    "severity",
    "action",
    "mergeability"
  ],
  "properties": {
    "id": {
      "type": "string",
      "description": "Stable slug for the entry."
    },
    "category": {
      "type": "string",
      "description": "Category slug used in API paths."
    },
    "title": {
      "type": "string",
      "description": "Display title."
    },
    "summary": {
      "type": "string",
      "description": "Short, high-signal description."
    },
    "tags": {
      "type": "array",
      "description": "Searchable tags for browsing and filtering.",
      "items": {
        "type": "string"
      },
      "minItems": 1
    },
    "tone": {
      "type": "string",
      "description": "Primary writing mode."
    },
    "version": {
      "type": "string",
      "description": "Content object schema version."
    },
    "created_at": {
      "type": "string",
      "description": "Initial publication date in ISO local date form."
    },
    "updated_at": {
      "type": "string",
      "description": "Most recent update date in ISO local date form."
    },
    "feedback": {
      "type": "string",
      "description": "Comment as written in the review."
    },
    "subtext": {
      "type": "string",
      "description": "What the reviewer actually means."
    },
    "severity": {
      "type": "string",
      "description": "How blocking the feedback really is.",
      "enum": [
        "low",
        "medium",
        "high",
        "critical"
      ]
    },
    "action": {
      "type": "string",
      "description": "Best next move for the author."
    },
    "mergeability": {
      "type": "string",
      "description": "Practical merge status.",
      "enum": [
        "blocked",
        "needs-context",
        "ready-with-risk",
        "ship-it"
      ]
    }
  }
}
