{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Meeting Entry",
  "description": "Recurring calendar rituals for alignment, deniability, and the steady conversion of ambiguity into notes no one will reopen.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "category",
    "title",
    "summary",
    "tags",
    "tone",
    "version",
    "created_at",
    "updated_at",
    "meeting_type",
    "stated_goal",
    "actual_goal",
    "output",
    "survivability"
  ],
  "properties": {
    "id": {
      "type": "string",
      "description": "Stable slug for the entry."
    },
    "category": {
      "type": "string",
      "description": "Category slug used in API paths."
    },
    "title": {
      "type": "string",
      "description": "Display title."
    },
    "summary": {
      "type": "string",
      "description": "Short, high-signal description."
    },
    "tags": {
      "type": "array",
      "description": "Searchable tags for browsing and filtering.",
      "items": {
        "type": "string"
      },
      "minItems": 1
    },
    "tone": {
      "type": "string",
      "description": "Primary writing mode."
    },
    "version": {
      "type": "string",
      "description": "Content object schema version."
    },
    "created_at": {
      "type": "string",
      "description": "Initial publication date in ISO local date form."
    },
    "updated_at": {
      "type": "string",
      "description": "Most recent update date in ISO local date form."
    },
    "meeting_type": {
      "type": "string",
      "description": "Type of meeting or ritual."
    },
    "stated_goal": {
      "type": "string",
      "description": "Official reason the calendar invite exists."
    },
    "actual_goal": {
      "type": "string",
      "description": "What the room is really trying to accomplish."
    },
    "output": {
      "type": "string",
      "description": "Most likely artifact or conclusion."
    },
    "survivability": {
      "type": "string",
      "description": "Likelihood of leaving with usable clarity.",
      "enum": [
        "low",
        "medium",
        "high"
      ]
    }
  }
}
