{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Token Entry",
  "description": "Judgment for wasteful AI usage, budget theater, and prompt loops that should have been one comment.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "category",
    "title",
    "summary",
    "tags",
    "tone",
    "version",
    "created_at",
    "updated_at",
    "token_spend",
    "waste_pattern",
    "guilt_level",
    "better_use",
    "finance_note"
  ],
  "properties": {
    "id": {
      "type": "string",
      "description": "Stable slug for the entry."
    },
    "category": {
      "type": "string",
      "description": "Category slug used in API paths."
    },
    "title": {
      "type": "string",
      "description": "Display title."
    },
    "summary": {
      "type": "string",
      "description": "Short, high-signal description."
    },
    "tags": {
      "type": "array",
      "description": "Searchable tags for browsing and filtering.",
      "items": {
        "type": "string"
      },
      "minItems": 1
    },
    "tone": {
      "type": "string",
      "description": "Primary writing mode."
    },
    "version": {
      "type": "string",
      "description": "Content object schema version."
    },
    "created_at": {
      "type": "string",
      "description": "Initial publication date in ISO local date form."
    },
    "updated_at": {
      "type": "string",
      "description": "Most recent update date in ISO local date form."
    },
    "token_spend": {
      "type": "number",
      "description": "Estimated token count consumed.",
      "minimum": 0
    },
    "waste_pattern": {
      "type": "string",
      "description": "The way the spend became embarrassing."
    },
    "guilt_level": {
      "type": "string",
      "description": "Waste severity level.",
      "enum": [
        "low",
        "medium",
        "high",
        "critical"
      ]
    },
    "better_use": {
      "type": "string",
      "description": "Something more defensible to spend the credits on."
    },
    "finance_note": {
      "type": "string",
      "description": "Dry financial commentary on the decision."
    }
  }
}
