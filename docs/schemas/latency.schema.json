{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Latency Entry",
  "description": "Response-time narratives for systems that stayed alive just long enough to ruin trust instead of availability charts.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "category",
    "title",
    "summary",
    "tags",
    "tone",
    "version",
    "created_at",
    "updated_at",
    "suspected_cause",
    "actual_cause",
    "mitigation",
    "graph_shape",
    "customer_story"
  ],
  "properties": {
    "id": {
      "type": "string",
      "description": "Stable slug for the entry."
    },
    "category": {
      "type": "string",
      "description": "Category slug used in API paths."
    },
    "title": {
      "type": "string",
      "description": "Display title."
    },
    "summary": {
      "type": "string",
      "description": "Short, high-signal description."
    },
    "tags": {
      "type": "array",
      "description": "Searchable tags for browsing and filtering.",
      "items": {
        "type": "string"
      },
      "minItems": 1
    },
    "tone": {
      "type": "string",
      "description": "Primary writing mode."
    },
    "version": {
      "type": "string",
      "description": "Content object schema version."
    },
    "created_at": {
      "type": "string",
      "description": "Initial publication date in ISO local date form."
    },
    "updated_at": {
      "type": "string",
      "description": "Most recent update date in ISO local date form."
    },
    "suspected_cause": {
      "type": "string",
      "description": "What people blamed first."
    },
    "actual_cause": {
      "type": "string",
      "description": "What was really responsible."
    },
    "mitigation": {
      "type": "string",
      "description": "Fastest practical move to buy time."
    },
    "graph_shape": {
      "type": "string",
      "description": "How the metric looked from the outside."
    },
    "customer_story": {
      "type": "string",
      "description": "How the issue showed up in real usage."
    }
  }
}
