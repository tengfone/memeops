{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Startup Entry",
  "description": "Absurd but plausible company ideas for an economy still trying to expense its way into product truth.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "category",
    "title",
    "summary",
    "tags",
    "tone",
    "version",
    "created_at",
    "updated_at",
    "pitch",
    "buyer",
    "moat",
    "risk",
    "investor_reaction"
  ],
  "properties": {
    "id": {
      "type": "string",
      "description": "Stable slug for the entry."
    },
    "category": {
      "type": "string",
      "description": "Category slug used in API paths."
    },
    "title": {
      "type": "string",
      "description": "Display title."
    },
    "summary": {
      "type": "string",
      "description": "Short, high-signal description."
    },
    "tags": {
      "type": "array",
      "description": "Searchable tags for browsing and filtering.",
      "items": {
        "type": "string"
      },
      "minItems": 1
    },
    "tone": {
      "type": "string",
      "description": "Primary writing mode."
    },
    "version": {
      "type": "string",
      "description": "Content object schema version."
    },
    "created_at": {
      "type": "string",
      "description": "Initial publication date in ISO local date form."
    },
    "updated_at": {
      "type": "string",
      "description": "Most recent update date in ISO local date form."
    },
    "pitch": {
      "type": "string",
      "description": "Short company description."
    },
    "buyer": {
      "type": "string",
      "description": "Who would allegedly pay for this."
    },
    "moat": {
      "type": "string",
      "description": "Reason it claims to be defensible."
    },
    "risk": {
      "type": "string",
      "description": "Most obvious structural problem."
    },
    "investor_reaction": {
      "type": "string",
      "description": "Likely response from a warmed-up partner meeting."
    }
  }
}
