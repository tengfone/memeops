{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Postmortem Entry",
  "description": "Mock incident narratives that read like real operational pain with better grammar and fewer redactions.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "category",
    "title",
    "summary",
    "tags",
    "tone",
    "version",
    "created_at",
    "updated_at",
    "failure_pattern",
    "customer_impact",
    "root_cause",
    "lesson",
    "corrective_action"
  ],
  "properties": {
    "id": {
      "type": "string",
      "description": "Stable slug for the entry."
    },
    "category": {
      "type": "string",
      "description": "Category slug used in API paths."
    },
    "title": {
      "type": "string",
      "description": "Display title."
    },
    "summary": {
      "type": "string",
      "description": "Short, high-signal description."
    },
    "tags": {
      "type": "array",
      "description": "Searchable tags for browsing and filtering.",
      "items": {
        "type": "string"
      },
      "minItems": 1
    },
    "tone": {
      "type": "string",
      "description": "Primary writing mode."
    },
    "version": {
      "type": "string",
      "description": "Content object schema version."
    },
    "created_at": {
      "type": "string",
      "description": "Initial publication date in ISO local date form."
    },
    "updated_at": {
      "type": "string",
      "description": "Most recent update date in ISO local date form."
    },
    "failure_pattern": {
      "type": "string",
      "description": "Named failure shape described in the write-up."
    },
    "customer_impact": {
      "type": "string",
      "description": "What users experienced."
    },
    "root_cause": {
      "type": "string",
      "description": "Actual technical cause."
    },
    "lesson": {
      "type": "string",
      "description": "What the team should stop pretending not to know."
    },
    "corrective_action": {
      "type": "string",
      "description": "Follow-up move with real leverage."
    }
  }
}
