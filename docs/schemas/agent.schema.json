{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Agent Entry",
  "description": "Performance reviews for coding agents, prompt workers, and synthetic coworkers who move faster than their consequences.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "category",
    "title",
    "summary",
    "tags",
    "tone",
    "version",
    "created_at",
    "updated_at",
    "performance_rating",
    "reliability_score",
    "hallucination_risk",
    "escalation_readiness",
    "strengths",
    "improvement_areas",
    "promotion_readiness",
    "manager_note"
  ],
  "properties": {
    "id": {
      "type": "string",
      "description": "Stable slug for the entry."
    },
    "category": {
      "type": "string",
      "description": "Category slug used in API paths."
    },
    "title": {
      "type": "string",
      "description": "Display title."
    },
    "summary": {
      "type": "string",
      "description": "Short, high-signal description."
    },
    "tags": {
      "type": "array",
      "description": "Searchable tags for browsing and filtering.",
      "items": {
        "type": "string"
      },
      "minItems": 1
    },
    "tone": {
      "type": "string",
      "description": "Primary writing mode."
    },
    "version": {
      "type": "string",
      "description": "Content object schema version."
    },
    "created_at": {
      "type": "string",
      "description": "Initial publication date in ISO local date form."
    },
    "updated_at": {
      "type": "string",
      "description": "Most recent update date in ISO local date form."
    },
    "performance_rating": {
      "type": "string",
      "description": "Fake HR performance band.",
      "enum": [
        "needs-improvement",
        "meets-expectations",
        "exceeds-expectations"
      ]
    },
    "reliability_score": {
      "type": "number",
      "description": "Operational trust score from 0 to 100.",
      "minimum": 0,
      "maximum": 100
    },
    "hallucination_risk": {
      "type": "string",
      "description": "Observed tendency to invent reality.",
      "enum": [
        "low",
        "medium",
        "high"
      ]
    },
    "escalation_readiness": {
      "type": "string",
      "description": "Likelihood that it asks for help before damage.",
      "enum": [
        "low",
        "medium",
        "high"
      ]
    },
    "strengths": {
      "type": "array",
      "description": "Behaviors a manager can say with a straight face.",
      "items": {
        "type": "string"
      },
      "minItems": 1
    },
    "improvement_areas": {
      "type": "array",
      "description": "Behaviors threatening the roadmap or pager.",
      "items": {
        "type": "string"
      },
      "minItems": 1
    },
    "promotion_readiness": {
      "type": "string",
      "description": "Whether more autonomy is survivable.",
      "enum": [
        "not-yet",
        "ready-with-oversight",
        "under-observation"
      ]
    },
    "manager_note": {
      "type": "string",
      "description": "One last sentence that should probably stay internal."
    }
  }
}
